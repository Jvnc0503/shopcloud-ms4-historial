# Example environment variables for MS4 service
# Copy this to `.env` and adjust values for your environment

ENVIRONMENT=development
DEBUG=false

# Upstream services
MS1_URL=http://ms1-productos:8001
MS2_URL=http://ms2-pedidos:8002
MS3_URL=http://ms3-usuarios:8003

# Request timeout in seconds (float)
REQUEST_TIMEOUT_SECONDS=10.0
